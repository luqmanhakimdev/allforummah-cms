{
  "name": "allforummah-cms",
  "version": "0.1.0",
  "private": true,
  "description": "CMS for All For Ummah website — SonicJS on Cloudflare Workers",
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy --env production",
    "db:migrate": "wrangler d1 migrations apply DB --remote --env production",
    "db:migrate:local": "wrangler d1 migrations apply DB --local",
    "db:reset": "sonicjs-db-reset",
    "db:studio": "drizzle-kit studio",
    "postinstall": "patch-package",
    "type-check": "tsc --noEmit",
    "test": "vitest --run",
    "test:watch": "vitest",
    "update": "npm install @sonicjs-cms/core@latest --save",
    "update:beta": "npm install @sonicjs-cms/core@beta --save",
    "update:plugin": "tsx scripts/update-plugin.ts",
    "seed": "tsx scripts/seed-admin.ts",
    "seed:prod": "tsx scripts/seed-admin.ts --remote",
    "set-password": "tsx scripts/set-password.ts",
    "set-password:prod": "tsx scripts/set-password.ts --remote"
  },
  "dependencies": {
    "@sonicjs-cms/core": "^3.0.0-beta.25"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20251202.0",
    "@types/node": "^24.10.1",
    "drizzle-kit": "^0.31.7",
    "drizzle-orm": "^0.44.7",
    "hono": "^4.10.7",
    "patch-package": "^8.0.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.15",
    "wrangler": "4.107.1",
    "zod": "^4.1.13"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
